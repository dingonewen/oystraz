# Application Settings
APP_NAME=Oystraz API
APP_VERSION=1.0.0
DEBUG=True

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/oystraz

# Security
SECRET_KEY=your-secret-key-change-this-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# External APIs
GEMINI_API_KEY=your-gemini-api-key-here
USDA_API_KEY=your-usda-api-key-here

# Character System Settings
STAMINA_DECAY_RATE=0.1
ENERGY_DECAY_RATE=0.15
NUTRITION_DECAY_RATE=0.2
